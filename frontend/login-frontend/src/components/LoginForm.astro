---
const eyeOpenIcon = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /></svg>`;
const eyeSlashIcon = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 0 0 1.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.451 10.451 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.522 10.522 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 1 0-4.243-4.243m4.242 4.242L6.228 6.228" /></svg>`;

const BACKEND_URL = import.meta.env.PUBLIC_BACKEND_URL || 'http://localhost:3001'; // URL del backend, se puede cambiar por la URL de produccion o por la URL de desarrollo
---

<div class="bg-white p-8 md:p-10 rounded-lg shadow-md w-full max-w-md">
    <div class="flex justify-center mb-6">
        <svg class="h-8 w-auto text-brand-black" viewBox="0 0 24 24" fill="currentColor">
            <path fill-rule="evenodd" d="M12.5 2.25a.75.75 0 0 0-1.5 0v11.25l-2.72-2.72a.75.75 0 0 0-1.06 1.06l4.25 4.25a.75.75 0 0 0 1.06 0l4.25-4.25a.75.75 0 1 0-1.06-1.06L12.5 13.5V2.25Z" clip-rule="evenodd" />
        </svg>
    </div>

    <h2 id="form-title" class="text-2xl font-semibold text-center text-gray-900 mb-6">Iniciar Sesión</h2>

    <form id="auth-form" class="space-y-5">
        <div id="name-field" class="hidden">
            <label for="name" class="block text-sm font-medium text-gray-700 sr-only">Nombre</label>
            <input type="text" name="name" id="name" autocomplete="name" placeholder="Escribe tu nombre" class="mt-1 block w-full px-4 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-300 focus:outline-none focus:ring-blue-400 focus:border-blue-400 sm:text-sm"/>
        </div>

        <div id="email-field" class="">
            <label for="email" class="block text-sm font-medium text-gray-700 sr-only"></label>
            <input type="email" name="email" id="email" autocomplete="email" placeholder="Escribe tu email" class="mt-1 block w-full px-4 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-300 focus:outline-none focus:ring-blue-400 focus:border-blue-400 sm:text-sm"/>
        </div>

        <div id="password-field" class="relative">
            <label for="password" class="block text-sm font-medium text-gray-700 sr-only"></label>
            <input type="password" name="password" id="password" autocomplete="password" placeholder="Escribe tu contraseña" class="mt-1 block w-full px-4 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-300 focus:outline-none focus:ring-blue-400 focus:border-blue-400 sm:text-sm"/>

            <button type="button" id="toggle-password" class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-400 hover:text-gray-500" aria-label="Mostrar contraseña">
                <span id="eye-icon" set:html={eyeSlashIcon}></span>
            </button>
        </div>

        <p id="error-message" class="text-red-400 text-sm text-center h-5"></p>

        <button type="submit" id="submit-button" class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-cyan-500 hover:bg-cyan-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-cyan-500">
            Iniciar sesion
        </button>

        <div class="text-center" id="forgot-password-link">
            <a href="#" class="text-sm text-gray-400 hover:text-gray-500">¿Olvidaste tu contraseña?</a>
        </div>

        <hr class="my-6 border-gray-400" />

        <div class="text-center">
            <p id="switch-mode-text" class="text-sm text-gray-400 mb-2">¿No tienes una cuenta creada?</p>
            <button type="button" id="switch-mode-button" class="w-full flex justify-center py-2 px-4 border border-gray-400 rounded-md shadow-sm text-sm font-medium text-black bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus_ring-blue-400">Crear una cuenta</button>
        </div>
    </form>
</div>

<script define:vars={{BACKEND_URL, eyeOpenIcon, eyeSlashIcon}}>
    const form = document.getElementById('auth-form');
    const nameField = document.getElementById('name-field');
    const emailInput = document.getElementById('email');
    const passwordInput = document.getElementById('password');
    const sumbitButton = document.getElementById('submit-button');
    const switchModeButton = document.getElementById('switch-mode-button');
    const switchModeText = document.getElementById('switch-mode-text');
    const formTitle = document.getElementById('form-title');
    const errorMessage = document.getElementById('error-message');
    const togglePasswordButton = document.getElementById('toggle-password');
    const eyeIcon = document.getElementById('eye-icon');
    const forgotPasswordLink = document.getElementById('forgot-password-link');

    let isLoginMode = true; // true for login, false for signup

    //logica para mostrar u ocultar la contraseña
    togglePasswordButton.addEventListener('click', () => {
        const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
        passwordInput.setAttribute('type', type);
        eyeIcon.innerHTML = type === 'password' ? eyeSlashIcon : eyeOpenIcon;
        togglePasswordButton.setAttribute('aria-label', type === 'password' ? 'Mostrar contraseña' : 'Ocultar contraseña');
    });

    //logica para cambiar entre modo login y signup
    const setMode = (loginMode) => {
        isLoginMode = loginMode;
        errorMessage.textContent = '';//limpiar campos y resetear estado del formulario
        form.reset();
        passwordInput.setAttribute('type', 'password');
        eyeIcon.innerHTML = eyeSlashIcon; //resetear icono de mostrar contraseña

        if (isLoginMode) {
            formTitle.textContent = 'Iniciar Sesion';
            sumbitButton.textContent = 'Iniciar Sesion';
            switchModeText.textContent = '¿No tienes una cuenta creada?';
            switchModeButton.textContent = 'Crear una cuenta';
            nameField.classList.add('hidden');
            forgotPasswordLink.classList.remove('hidden');
            passwordInput.setAttribute('autocomplete', 'current-password');
        } else {
            formTitle.textContent = 'Crear Cuenta';
            sumbitButton.textContent = 'Crear Cuenta';
            switchModeText.textContent = '¿Ya tienes una cuenta?';
            switchModeButton.textContent = 'Iniciar Sesion';
            nameField.classList.remove('hidden');
            forgotPasswordLink.classList.add('hidden');
            passwordInput.setAttribute('autocomplete', 'new-password');
        }
    };

    switchModeButton.addEventListener('click', () => setMode(!isLoginMode));

    //logica para manejar el submit del formulario tanto para login como para signup
    form.addEventListener('submit', async (event) => {
        event.preventDefault(); //prevenir comportamiento por defecto del formulario
        errorMessage.textContent = ''; //limpiar mensaje de error previo

        const name = nameField.querySelector('input').value;
        const email = emailInput.value;
        const password = passwordInput.value;

        //validar campos requeridos
        if (isLoginMode && (!email || !password)) {
            errorMessage.textContent = 'Por favor, completa todos los campos.';
            return;
        }

        const endpoint = isLoginMode ? `${BACKEND_URL}/api/auth/login` : `${BACKEND_URL}/api/auth/register`;
        const body = isLoginMode ? { email, password } : { name, email, password };

        try {
            sumbitButton.disabled = true; //deshabilitar boton para evitar multiples clicks
            sumbitButton.textContent = 'Cargando...'; //mostrar estado de carga

            // Debug: mostrar endpoint y body antes de enviar la petición
            console.log('POST', endpoint, body);

            const response = await fetch(endpoint, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(body),
            });

            const data = await response.json();

            if (!response.ok) throw new Error(data.message || `Error ${response.status}`);

            //guardar token y datos del usuario en localStorage para mantener la sesion iniciada, luego redirigir al usuario a la pagina principal
            localStorage.setItem('jwtToken', data.token);
            localStorage.setItem('userName', data.user.name);
            localStorage.setItem('userEmail', data.user.email);

            window.location.href = '/home'; //redireccionar a la pagina principal despues de iniciar sesion o registrarse exitosamente
        } catch (error) {
            console.error('error de autenticacion - endpoint:', endpoint, error);
            errorMessage.textContent = error.message || 'Error de autenticacion';
            sumbitButton.disabled = false;
            sumbitButton.textContent = isLoginMode ? 'Iniciar Sesion' : 'Crear Cuenta';
        }
    });

    setMode(true); //iniciar en modo login por defecto para mostrar el formulario de inicio de sesion al cargar la pagina
</script>